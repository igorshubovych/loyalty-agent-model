      </pen>
    </plot>
    <plot x="295" autoPlotX="true" yMax="100.0" autoPlotY="true" yAxis="cumulative $ sales" y="270" xMin="0.0" height="250" legend="true" xMax="30.0" yMin="0.0" width="445" xAxis="days" display="Cumulative Sales per Brand ($)">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Zappa" color="-14714956" legend="true">
