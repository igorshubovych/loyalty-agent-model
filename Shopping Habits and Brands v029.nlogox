<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="true">
  <code><![CDATA[; ============================================================
; MODEL STATE
; ============================================================

globals [
  ; --- runtime state (reset or updated every run/tick) ---
  total-sales          ; $, cumulative money customers have spent
  total-profit         ; $, cumulative shop profit net of unit costs
  brand-sales          ; list, cumulative $ sales per brand
  brand-profit         ; list, cumulative $ profit per brand
  daily-units          ; list, units sold per brand during the current day
  broke-customers      ; customers who wanted to shop but could not afford it
  brand-names          ; list, display name of each brand
  ; --- calibration: population and catalog ---
  num-customers        ; number of shopping agents
  num-brands           ; number of brands competing in the one category
  ; --- calibration: prices and discounts ---
  min-price            ; $, lower bound of brand prices
  max-price            ; $, upper bound of brand prices
  cost-share           ; fraction of the price the shop pays per unit
  brand-discount-rate  ; price cut applied while a brand is on discount
  ; --- calibration: budgets and baskets ---
  min-base-budget      ; $, lower bound of an agent's base daily money
  max-base-budget      ; $, upper bound of an agent's base daily money
  budget-noise-share   ; relative size of the daily budget fluctuation
  max-units            ; a purchase is 1..max-units units of the chosen brand
  ; --- calibration: shopping-frequency habit ---
  shop-prob-init       ; initial probability a customer shops on a given day
  shop-gain            ; step up in shop probability after a satisfied trip
  shop-loss            ; step down after an unmet trip
  ; --- calibration: habitual vs deliberate choice ---
  beta-loyalty         ; weight of loyalty score in choice utility
  beta-price           ; weight of price, used only when deliberating
  outside-utility      ; utility of buying nothing
  deliberation-prob    ; baseline chance of deliberating over habit
  ; --- calibration: reward-scaled reinforcement ---
  reward-neutral       ; satisfaction giving no loyalty change
  reward-price-weight  ; reward share from price vs. amount bought
  ; --- calibration: brand loyalty (plain scores) ---
  min-initial-loyalty  ; lower bound of the initial loyalty scores
  max-initial-loyalty  ; upper bound of the initial loyalty scores
  loyalty-gain         ; score step scale for the brand just bought
  loyalty-decay        ; score step down for its rivals after a good buy
  loyalty-forget-rate  ; daily fraction by which every score fades to 0
  ; --- calibration: supply (order-up-to with random lead time) ---
  order-up-to-level    ; target shelf stock the shop reorders toward
  max-lead-time        ; ticks, longest random delivery lead time
  ; --- calibration: run length ---
  simulation-days      ; ticks, day at which the go button stops
]

breed [ brands brand ]        ; one brand sold in the category
breed [ customers customer ]  ; the shopping agents

brands-own [
  brand-id        ; index 0..num-brands-1, matches the loyalty list position
  brand-name      ; display name
  price           ; $, catalog price of one unit
  cost            ; $, what the shop pays for one unit
  stock           ; units currently on the shelf
  on-order        ; units in transit toward the shelf
  lead-timer      ; ticks until the in-transit order arrives, 0 if none
  discount-timer  ; ticks left of an active discount, 0 if none
]

customers-own [
  base-budget  ; $, personal base amount of daily shopping money
  wallet       ; $, money left to spend today
  shop-prob    ; probability this customer shops on a given day
  loyalties    ; list of loyalty scores, one per brand (index = brand-id)
]

; ============================================================
; SETUP
; ============================================================

to setup
  clear-all
  setup-calibration
  set total-sales 0
  set total-profit 0
  set brand-sales n-values num-brands [ 0 ]
  set brand-profit n-values num-brands [ 0 ]
  set daily-units n-values num-brands [ 0 ]
  set broke-customers 0
  setup-brands
  setup-customers
  reset-ticks
end

; Single source of truth for every tunable coefficient, so BehaviorSpace
; and sensitivity sweeps can vary the model without touching procedures.
to setup-calibration
  ; --- population and catalog ---
  set num-customers 200
  set num-brands 8
  ; --- prices and discounts ---
  set min-price 1
  set max-price 10
  set cost-share 0.7
  set brand-discount-rate 0.35
  ; --- budgets and baskets ---
  set min-base-budget 5
  set max-base-budget 15
  set budget-noise-share 0.1
  set max-units 3
  ; --- shopping-frequency habit ---
  set shop-prob-init 0.6
  set shop-gain 0.1
  set shop-loss 0.1
  ; --- habitual vs deliberate choice ---
  set beta-loyalty 2.5
  set beta-price 2
  set outside-utility 1.5
  set deliberation-prob 0.2
  ; --- reward-scaled reinforcement ---
  set reward-neutral 0.5
  set reward-price-weight 0.7
  ; --- brand loyalty (plain scores) ---
  set min-initial-loyalty -0.3
  set max-initial-loyalty 0.3
  set loyalty-gain 0.8
  set loyalty-decay 0.15
  set loyalty-forget-rate 0.02
  ; --- supply (order-up-to with random lead time) ---
  set order-up-to-level 40
  set max-lead-time 5
  ; --- run length ---
  set simulation-days 365
  set brand-names
    ["Zappa" "Kova" "Nuvo" "Fizzo" "Blip" "Gusto" "Vibe" "Munch"]
end

to setup-brands
  foreach range num-brands [ b ->
    create-brands 1 [
      hide-turtle
      set brand-id b
      set brand-name item b brand-names
      set price min-price + random-float (max-price - min-price)
      set cost price * cost-share
      set stock random (order-up-to-level + 1)
      set on-order 0
      set lead-timer 0
      set discount-timer 0
    ]
  ]
end

to setup-customers
  create-customers num-customers [
    hide-turtle
    set base-budget min-base-budget +
      random-float (max-base-budget - min-base-budget)
    set wallet 0
    set shop-prob shop-prob-init
    set loyalties n-values num-brands
      [ min-initial-loyalty +
        random-float (max-initial-loyalty - min-initial-loyalty) ]
  ]
end

; ============================================================
; MAIN LOOP
; ============================================================

; One tick is one shopping day: deliveries arrive, every customer decides
; whether to shop and (if so) buys and learns, then the shop reorders.
to go
  if ticks >= simulation-days [ stop ]
  set daily-units n-values num-brands [ 0 ]
  set broke-customers 0
  ask brands [ receive-delivery ]
  ask customers [ receive-daily-budget shop ]
  ask brands [ age-discount place-order ]
  tick
end

; ============================================================
; SUPPLY AND DISCOUNTS
; ============================================================

to receive-delivery  ; brand procedure
  if lead-timer > 0 [
    set lead-timer lead-timer - 1
    if lead-timer = 0 [
      set stock stock + on-order
      set on-order 0
    ]
  ]
end

to place-order  ; brand procedure
  ; order-up-to policy: one outstanding order, random lead time
  if lead-timer = 0 and stock < order-up-to-level [
    set on-order order-up-to-level - stock
    set lead-timer 1 + random max-lead-time
  ]
end

to age-discount  ; brand procedure
  if discount-timer > 0 [ set discount-timer discount-timer - 1 ]
end

to discount-brand [ b ]
  ; a brand button puts that brand on sale for the next discount-days days
  ask brands with [ brand-id = b ] [ set discount-timer discount-days ]
end

; ============================================================
; SHOPPING: THE DECISION
; ============================================================
 
to receive-daily-budget  ; customer procedure
  set wallet base-budget * (1 + budget-noise-share * (random-float 2 - 1))
end

; shop -- one shopping day. With probability shop-prob the customer makes a
; trip; a satisfying trip raises that probability and an unmet one lowers it
; (the shopping-frequency habit). Whether or not a trip happens, every
; loyalty fades a little at the end (habits need repetition to last).
to shop  ; customer procedure
  if random-float 1 < shop-prob [ make-trip ]
  forget-loyalties
end

to make-trip  ; customer procedure
  let available brands with [ stock > 0 ]
  ifelse not any? available [
    weaken-shop-habit
  ] [
    ifelse wallet < min [ effective-price ] of available [
      set broke-customers broke-customers + 1
    ] [
      let chosen choose-brand available
      ifelse chosen = nobody [ weaken-shop-habit ] [ buy-from chosen ]
    ]
  ]
end

; choose-brand -- the core decision. Habit is the DEFAULT and it is model-
; free: the softmax weight of each in-stock brand comes from its loyalty
; score alone. On a minority of occasions the customer DELIBERATES and
; price also enters (see deliberating?). A no-buy option always competes.
; One option is drawn in proportion to its weight; nobody means no purchase.
to-report choose-brand [ available ]  ; customer reporter
  let deliberate? deliberating? available
  let options lput nobody (sort available)
  let weights map [ o -> option-weight o deliberate? ] options
  report weighted-pick options weights
end

to-report option-weight [ o deliberate? ]  ; customer reporter
  ; o is an in-stock brand, or nobody for the no-buy option
  if o = nobody [ report exp outside-utility ]
  let u beta-loyalty * item ([ brand-id ] of o) loyalties
  if deliberate? [ set u u + beta-price * [ price-satisfaction ] of o ]
  report exp u
end

; deliberating? -- the exploration trigger. Deliberation fires with a small
; baseline probability, and always when the customer's usual brand (its
; highest-loyalty brand) is out of stock, because the broken cue forces a
; fresh comparison.
to-report deliberating? [ available ]  ; customer reporter
  let usual usual-brand
  if any? available with [ brand-id = usual ] [
    report random-float 1 < deliberation-prob
  ]
  report true
end

to-report usual-brand  ; customer reporter
  ; brand-id of the highest-loyalty brand - this customer's favourite
  report position (max loyalties) loyalties
end

to-report weighted-pick [ items weights ]
  ; return one item chosen with probability proportional to its weight
  let target random-float sum weights
  let cum 0
  let i 0
  foreach items [ it ->
    set cum cum + item i weights
    if target < cum [ report it ]
    set i i + 1
  ]
  report last items
end

; ============================================================
; LEARNING: PURCHASE, REINFORCEMENT, FORGETTING
; ============================================================

; buy-from -- the customer buys 1..max-units units of the chosen brand,
; stopping early if the shelf empties or the wallet runs dry, tallying the
; takings as it goes. Getting the wanted amount is a satisfying trip; a
; short one is not. A purchase then reinforces the brand in proportion to
; how rewarding it was.
to buy-from [ chosen ]  ; customer procedure
  let desired 1 + random max-units
  let bought 0
  while [ bought < desired
          and [ stock ] of chosen > 0
          and wallet >= [ effective-price ] of chosen ] [
    let paid [ effective-price ] of chosen
    let b [ brand-id ] of chosen
    let unit-profit paid - [ cost ] of chosen
    set wallet wallet - paid
    set total-sales total-sales + paid
    set total-profit total-profit + unit-profit
    set brand-sales replace-item b brand-sales (item b brand-sales + paid)
    set brand-profit
      replace-item b brand-profit (item b brand-profit + unit-profit)
    set daily-units replace-item b daily-units (item b daily-units + 1)
    ask chosen [ set stock stock - 1 ]
    set bought bought + 1
  ]
  ifelse bought >= desired [ strengthen-shop-habit ] [ weaken-shop-habit ]
  if bought >= 1 [ reinforce chosen (purchase-reward chosen bought desired) ]
end

; purchase-reward -- how satisfying the purchase was, in [0,1]: a blend of
; how cheap the brand was and how much of the wanted amount was bought.
to-report purchase-reward [ the-brand bought desired ]  ; customer reporter
  report reward-price-weight * [ price-satisfaction ] of the-brand
    + (1 - reward-price-weight) * (bought / desired)
end

; reinforce -- the chosen brand's score moves by loyalty-gain x (reward -
; reward-neutral): a satisfying buy raises it, a poor one lowers it. After a
; satisfying buy the rival brands' scores drop a little, so wins build a
; lead. This plain score, fed through the softmax in choose-brand, is what
; produces habit and lock-in - no probabilities or log-odds needed.
to reinforce [ chosen reward ]  ; customer procedure
  let b [ brand-id ] of chosen
  set loyalties replace-item b loyalties
    (item b loyalties + loyalty-gain * (reward - reward-neutral))
  if reward >= reward-neutral [
    foreach range num-brands [ other1 ->
      if other1 != b [ set loyalties replace-item other1 loyalties (item other1 loyalties - loyalty-decay) ]
    ]
  ]
end

to forget-loyalties  ; customer procedure
  ; every score fades toward 0 (equal preference) unless it is renewed
  set loyalties map [ s -> s * (1 - loyalty-forget-rate) ] loyalties
end

to strengthen-shop-habit  ; customer procedure
  set shop-prob shop-prob + shop-gain * (1 - shop-prob)
end

to weaken-shop-habit  ; customer procedure
  set shop-prob shop-prob - shop-loss * shop-prob
end

; ============================================================
; REPORTERS (plots and monitors)
; ============================================================

to-report effective-price  ; brand procedure
  report ifelse-value discount-timer > 0
    [ price * (1 - brand-discount-rate) ]
    [ price ]
end

to-report price-satisfaction  ; brand procedure
  ; absolute: cheapest price gives 1, dearest gives 0
  report clamp01 ((max-price - effective-price) / (max-price - min-price))
end

to-report clamp01 [ x ]
  report max list 0 (min list 1 x)
end

to-report brand-share [ b ]
  ; percent of today's units that were brand b
  let total sum daily-units
  report ifelse-value total > 0 [ item b daily-units / total * 100 ] [ 0 ]
end

to-report bar-color [ the-brand ]
  ; on-sale brands stand out in magenta; the rest are grey
  report ifelse-value [ discount-timer ] of the-brand > 0 [ magenta ] [ grey ]
end

to-report brands-on-sale
  ; names and days-left of every brand currently discounted, for a monitor
  let sale sort brands with [ discount-timer > 0 ]
  if empty? sale [ report "none" ]
  report reduce [ [ a b ] -> (word a "    " b) ]
    map [ the-brand ->
      (word [ brand-name ] of the-brand " " [ discount-timer ] of the-brand "d") ]
    sale
end

to-report price-list [ lo hi ]
  ; brands lo..hi with prices; a discounted brand shows its sale price
  let text ""
  foreach sort brands with [ brand-id >= lo and brand-id <= hi ]
    [ the-brand ->
      if text != "" [ set text (word text "    ") ]
      set text (word text [ price-label ] of the-brand)
  ]
  report text
end

to-report price-label  ; brand reporter
  ifelse discount-timer > 0
    [ report (word brand-name " $" precision effective-price 2 " SALE") ]
    [ report (word brand-name " $" precision price 2) ]
end]]></code>
