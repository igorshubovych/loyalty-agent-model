    <monitor x="150" precision="2" y="290" height="60" fontSize="11" width="135" display="total profit ($)">total-profit</monitor>
    <monitor x="10" precision="0" y="340" height="60" fontSize="11" width="135" display="% broke today">broke-customers / num-customers * 100</monitor>
    <monitor x="10" precision="0" y="390" height="60" fontSize="11" width="275" display="on sale now">brands-on-sale</monitor>
    <monitor x="10" precision="0" y="440" height="60" fontSize="11" width="275" display="prices (1-4)">price-list 0 3</monitor>
    <monitor x="10" precision="0" y="490" height="60" fontSize="11" width="275" display="prices (5-8)">price-list 4 7</monitor>
    <plot x="295" autoPlotX="true" yMax="100.0" autoPlotY="true" yAxis="% of daily units" y="10" xMin="0.0" height="250" legend="true" xMax="30.0" yMin="0.0" width="445" xAxis="days" display="Market Share per Brand (%)">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Zappa" color="-14714956" legend="true">
